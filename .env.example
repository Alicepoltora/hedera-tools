# Hedera Network Configuration
HEDERA_NETWORK=testnet           # testnet | mainnet | previewnet
OPERATOR_ACCOUNT_ID=0.0.XXXXXX
OPERATOR_PRIVATE_KEY=302e...

# Mirror Node
MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com

# App Config
PORT=3000
NODE_ENV=development

# WalletConnect — required for real wallet connection on the demo site
# Get your free Project ID at https://cloud.walletconnect.com
# If not set, the demo site runs in demo mode (simulated wallet)
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here
